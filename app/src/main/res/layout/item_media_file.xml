<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/item_root_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/image_album_art"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/default_album_art_144px"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="@string/cd_album_art"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/text_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textSize="13sp"
            android:textColor="@color/titleColor"
            android:singleLine="true"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/image_album_art"
            app:layout_constraintEnd_toStartOf="@id/button_save_edit"
            app:layout_constraintBottom_toTopOf="@+id/text_duration"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="Song Title Here (feat. Artist)" />

        <TextView
            android:id="@+id/text_duration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textSize="12sp"
            android:textColor="@color/subtitleColor"
            android:singleLine="true"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/text_title"
            app:layout_constraintStart_toStartOf="@id/text_title"
            app:layout_constraintEnd_toStartOf="@id/button_save_edit"
            app:layout_constraintBottom_toTopOf="@+id/text_details"
            tools:text="3:45" />

        <TextView
            android:id="@+id/text_details"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textSize="11sp"
            android:textColor="#808080"
            android:singleLine="true"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/text_duration"
            app:layout_constraintStart_toStartOf="@id/text_title"
            app:layout_constraintEnd_toStartOf="@id/button_save_edit"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="1920x1080 ✦ 24.5 MB" />

        <EditText
            android:id="@+id/edit_text_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:singleLine="true"
            android:imeOptions="actionNext"
            android:inputType="textCapWords"
            android:textSize="14sp"
            android:textColor="@color/titleColor"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/image_album_art"
            app:layout_constraintEnd_toStartOf="@id/button_save_edit"
            tools:text="Song Title Here"
            tools:visibility="gone"/>

        <EditText
            android:id="@+id/edit_text_artist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:inputType="textCapWords"
            android:textSize="12sp"
            android:textColor="@color/subtitleColor"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/edit_text_title"
            app:layout_constraintStart_toStartOf="@id/edit_text_title"
            app:layout_constraintEnd_toStartOf="@id/button_save_edit"
            tools:text="Artist Name"
            tools:visibility="gone"/>

        <ImageButton
            android:id="@+id/button_save_edit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:contentDescription="Save Changes"
            android:padding="8dp"
            android:src="@drawable/save_24px"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/gmaGreenDarkMono"
            tools:visibility="visible"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>